{
  "name": "diversifi-minipay",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.11.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev -p 3042",
    "build": "turbo run build --filter=@diversifi/shared --filter=@stable-station/mento-utils && npx tsc --noEmit && next build --webpack",
    "start": "next start -p 3042",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "turbo clean && rm -rf .next out node_modules cache .cache",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "setup-arc-agent": "node scripts/setup-arc-agent.js",
    "create-wallet": "npx tsx --env-file=.env.local scripts/create-circle-wallet.ts",
    "test-x402": "node tests/test-x402-hub.mjs",
    "test-x402-comprehensive": "node tests/test-x402-comprehensive.mjs",
    "test-x402-frequency": "node tests/test-x402-frequency.mjs",
    "generate-x402-volume": "node scripts/generate-x402-volume.mjs",
    "validate-agent": "npx tsx -e \"import { validateAgentConfig } from './packages/shared/src/utils/arc-agent-setup'; console.log(validateAgentConfig());\"",
    "register-agent": "npx tsx scripts/register-on-agentscan.ts",
    "register-erc8004": "npx tsx scripts/register-erc8004.ts"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "1.2.9",
    "@celo/blind-threshold-bls": "1.0.0-beta",
    "@celo/identity": "5.1.2",
    "@celo/poprf": "0.1.9",
    "@circle-fin/developer-controlled-wallets": "10.0.1",
    "@diversifi/shared": "workspace:*",
    "@diversifi/shared-0g": "workspace:*",
    "@farcaster/miniapp-sdk": "0.2.1",
    "@google/generative-ai": "0.24.1",
    "@lifi/sdk": "3.15.3",
    "@privy-io/node": "0.11.0",
    "@privy-io/react-auth": "3.13.1",
    "@privy-io/wagmi": "4.0.1",
    "@quicknode/x402": "0.1.3",
    "@selfxyz/agent-sdk": "0.2.1",
    "@selfxyz/qrcode": "1.0.24",
    "@stable-station/mento-utils": "workspace:*",
    "@tanstack/react-query": "5.90.21",
    "@vercel/og": "0.8.6",
    "assert": "2.1.0",
    "autoprefixer": "^10.4.0",
    "axios": "1.13.2",
    "browserify-zlib": "0.2.0",
    "buffer": "6.0.3",
    "canvas-confetti": "1.9.4",
    "crypto-browserify": "3.12.1",
    "ethers6": "npm:ethers@^6.16.0",
    "formidable": "3.5.4",
    "framer-motion": "12.26.2",
    "https-browserify": "1.0.0",
    "mongoose": "9.2.0",
    "next": "16.2.6",
    "openai": "6.16.0",
    "os-browserify": "0.3.0",
    "postcss": "^8.4.0",
    "process": "0.11.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stream-browserify": "3.0.0",
    "stream-http": "3.2.0",
    "tailwindcss": "^3.4.1",
    "url": "0.11.4",
    "util": "0.12.5",
    "viem": "^2.37.0",
    "wagmi": "^2.14.15"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.6",
    "@resvg/resvg-js": "2.6.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/canvas-confetti": "1.9.0",
    "@types/formidable": "3.4.6",
    "@types/node": "^22.8.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "ethers": "^5.7.2",
    "jsdom": "29.0.0",
    "satori": "0.26.0",
    "tsx": "4.22.4",
    "turbo": "^2.1.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.30.0",
  "peerDependencies": {
    "ethers": "^6.16.0"
  },
  "pnpm": {
    "overrides": {
      "viem": "2.44.2"
    }
  }
}
