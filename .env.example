NEXT_PUBLIC_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/demo
NEXT_PUBLIC_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# Server-side / Foundry RPC endpoints (may include API keys)
CELO_RPC_URL=https://forno.celo.org
ARBITRUM_ONE_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Foundry Deploy Keys (Keep Secret!)
# Deployer private key — must have ETH on the target chain for gas
PRIVATE_KEY=

# Payment token address for the target chain
# Arbitrum One:   0xaf88d065e77c8cC2239327C5EDb3A432268e5831 (USDC)
# Arbitrum Sepolia: 0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d (USDC)
# Celo:           0x765DE816845861e75A25fCA122bb6898B8B1282a (cUSD)
PAYMENT_TOKEN_ADDRESS=

# RPC URLs for forge deployments (set from Alchemy/Infura, or use x402 proxy)
# Option A: x402 proxy (pay-per-request, no API key — run: node scripts/x402-proxy.mjs)
#   forge uses http://localhost:9545
# Option B: Traditional QuickNode / Alchemy endpoint
ARBITRUM_ONE_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
CELO_RPC_URL=
CELO_SEPOLIA_RPC_URL=

# x402 Proxy Configuration (for pay-per-request RPC via QuickNode)
# Payment happens on testnet! Get testnet USDC from Circle Faucet.
# Payment network CAIP-2 ID (chain where you hold testnet USDC to pay for requests)
# eip155:84532 = Base Sepolia (recommended), eip155:80002 = Polygon Amoy
X402_PAYMENT_NETWORK=eip155:84532
# Wallet private key (EVM) with testnet USDC on the payment network
X402_EVM_PRIVATE_KEY=
# QuickNode chain slug — https://x402.quicknode.com/<slug>
X402_TARGET_CHAIN=arbitrum-mainnet
# Local proxy port (default 9545)
X402_PROXY_PORT=9545

# MongoDB Connection (for streak persistence)
# Get from MongoDB Atlas: https://www.mongodb.com/atlas
# Project: Diversifi (ID: 69c179dc1e75024408e787dd)
# Cluster: DiversifiCluster (Free tier M0, US_EAST_1)
# User: diversifi-user
# IP Whitelist: Only your server IP (no 0.0.0.0/0!)
MONGODB_URI=mongodb+srv://diversifi-user:YOUR_PASSWORD_HERE@diversificluster.cxx3kmd.mongodb.net/DiversifiCluster?retryWrites=true&w=majority

# Note: DeFiLlama, Yearn Finance, and World Bank APIs are FREE and need no keys!

# Hetzner backend — routes heavy AI API calls (analyze, chat, x402-gateway) to always-on server
# Eliminates Vercel cold starts and 15s timeout for Oracle/Guardian routes
# Leave unset to fall back to Vercel serverless (works fine, just slower)
HETZNER_API_URL=https://api.diversifi.famile.xyz

# 0G Serving (Decentralized AI Inference)
# OpenAI-compatible Router API: https://router-api.0g.ai/v1
# Get from 0G Discord or 0G Dashboard: https://docs.0g.ai/developer-hub/building-on-0g/compute-network/inference
# Verified models: deepseek-chat-v3-0324 (default), qwen-2.5-72b-instruct, llama-3.3-70b-instruct
# Serves as decentralized inference provider in AI failover chain
ZERO_G_SERVING_API_KEY=
# Override the default 0G Serving model (e.g. qwen-2.5-72b-instruct).
# Leave blank to use the provider default.
ZERO_G_SERVING_MODEL=

# Arbitrum Recommendation Ledger Contract (set after deployment)
# Arbitrum Sepolia (testnet) — set after running deploy-all.sh arbitrum_sepolia
ARBITRUM_LEDGER_CONTRACT=
# Arbitrum mainnet (yield decisions of record) — set after deploying to mainnet
ARBITRUM_MAINNET_LEDGER_CONTRACT=
ARBITRUM_MAINNET_CHAIN_ID=42161

# Arbitrum StrategyVault + AgenticHub contracts (set after deployment)
ARBITRUM_VAULT_CONTRACT=
ARBITRUM_HUB_CONTRACT=

# Celo mainnet RecommendationLedger (savings decisions of record)
# Set after deploying to Celo mainnet: forge script scripts/DeployRecommendationLedger.s.sol --rpc-url celo --broadcast
CELO_MAINNET_LEDGER_CONTRACT=

# HashKey mainnet RecommendationLedger — the APAC rail (docs/apac-rail.md).
# APAC savings decisions of record (Confucian / Gotong Royong plans, Asia region).
# Deploy: ./scripts/deploy-all.sh hashkey   (needs HSK for gas on chain 177)
# Set BOTH vars to the same address — the NEXT_PUBLIC_ one gates client copy.
HASHKEY_LEDGER_CONTRACT=
NEXT_PUBLIC_HASHKEY_LEDGER_CONTRACT=
HASHKEY_RPC_URL=https://mainnet.hsk.xyz

# ----------------------------------------------------------------------------
# HSP (HashKey Settlement Protocol) — zero-custody settlement rail on HashKey.
# Powers the "FX Protection Insight" paid source, settled via HSP and anchored
# on the HashKey RecommendationLedger. Testnet-first (chain 133); flip to mainnet
# (177) only after a full testnet settle+anchor loop passes.
#
# To activate as the x402 rail: SETTLEMENT_NETWORK=HASHKEY (see MAINNET FLIP below).
#
# Obtain these from the HSP Coordinator (self-service /register gives the API key;
# the faucet drips testnet gas + USDC). The token + verifyingContract are read
# authoritatively from `GET <coordinator>/chains` at runtime — the values below
# are fallbacks only.
HSP_COORDINATOR_URL=
HSP_API_KEY=
# Coordinator chain names (defaults shown). SETTLEMENT_ENV selects which is used.
HSP_CHAIN_NAME_TESTNET=hashkey-testnet
HSP_CHAIN_NAME_MAINNET=hashkey
# EIP-712 domain verifyingContract fallbacks (authoritative value from GET /chains).
HSP_VERIFYING_CONTRACT_TESTNET=
HSP_VERIFYING_CONTRACT_MAINNET=
# HashKey testnet (chain 133) RPC. HSP token comes from GET /chains at runtime.
HASHKEY_TESTNET_RPC_URL=https://testnet.hsk.xyz
NEXT_PUBLIC_HASHKEY_TESTNET_RPC_URL=https://testnet.hsk.xyz
HASHKEY_TESTNET_USDC=
HASHKEY_TESTNET_USDT=
HASHKEY_MAINNET_RPC_URL=https://mainnet.hsk.xyz
# Merchant/data-hub payout address on HashKey (defaults to DATA_HUB_RECIPIENT_ADDRESS).
HASHKEY_PAY_RECIPIENT=
#
# --- Plain-transfer settlement on HashKey (no Coordinator / no KYC) --------------
# The PLAIN on-chain settlement path (SETTLEMENT_NETWORK=HASHKEY, without HSP) uses
# these. Verified on-chain (both 6 decimals): USDT is HashKey mainnet's canonical
# stablecoin; bridged USDC also exists. Settlement defaults to USDT.
HASHKEY_MAINNET_USDT=0xf1b50ed67a9e2cc94ad3c477779e2d4cbfff9029
HASHKEY_MAINNET_USDC=0x054ed45810DbBAb8B27668922D110669c9D88D0a
# Override the settlement token address explicitly (else defaults to USDT above).
HASHKEY_SETTLEMENT_TOKEN=
#
# --- HashKey FX demo (scripts/hashkey-fx-demo.ts) -------------------------------
# anchor mode (free, HSK gas only): records the FX recommendation on HashKey 177.
DEMO_IMPORTER_ADDRESS=
# settle mode (needs USDT + a running gateway with SETTLEMENT_NETWORK=HASHKEY):
GATEWAY_URL=http://localhost:3000
DEMO_PAYER_PRIVATE_KEY=

# 0G Recommendation Ledger Contract (evidence anchor/mirror)
# 0G is the evidence layer — Storage holds reasoning CIDs, this contract
# records cross-chain verifiable references to those CIDs
ZERO_G_LEDGER_CONTRACT=
# 0G mainnet RPC + ledger (evidence anchor — deployed at 0x3BCf…369C)
ZERO_G_MAINNET_RPC_URL=https://evmrpc.0g.ai
ZERO_G_MAINNET_LEDGER_CONTRACT=0x3BCf7dFd68ce98880618c89A351168960724369C
# Ledger signer — the deployer wallet authorized as an agent on all 3 chains.
# Preferred over VAULT_PRIVATE_KEY for ledger writes.
LEDGER_PRIVATE_KEY=
# Guardian heartbeat agent address (records advisory recommendations)
GUARDIAN_AGENT_ADDRESS=
# 0G Pay recipient (used by settlement-service.ts for x402 nanopayments on 0G)
ZERO_G_PAY_RECIPIENT=

# ============================================================================
# MAINNET FLIP — flip DiversiFi from testnet to mainnet with config only.
# ----------------------------------------------------------------------------
# Two subsystems settle on-chain and each has an independent, additive switch.
# Defaults below keep everything on testnet; set the vars in each step to flip.
#
# 1) RECOMMENDATION LEDGER (on-chain decision record) — ALREADY mainnet-gated.
#    The ledger auto-prefers a mainnet chain the moment its contract address is
#    set (see the *_MAINNET_LEDGER_CONTRACT vars above). All three are already
#    deployed at 0x3BCf…369C. Fund LEDGER_PRIVATE_KEY on Celo/Arbitrum/0G and
#    the ledger writes to mainnet. No further switch needed.
#
# 2) x402 SETTLEMENT (nanopayment rail) — the flip staged here.
#    SETTLEMENT_NETWORK  chooses the rail:        'ZERO_G' (interim) | 'ARC' | 'ARBITRUM' | 'HASHKEY'
#    SETTLEMENT_ENV      chooses testnet|mainnet: 'testnet' (default) | 'mainnet'
#    e.g. SETTLEMENT_NETWORK=ZERO_G + SETTLEMENT_ENV=mainnet → settle on 0G mainnet.
#    SETTLEMENT_NETWORK=HASHKEY settles via HSP on HashKey (see the HSP block above);
#    it needs HSP_COORDINATOR_URL + HSP_API_KEY and a funded HashKey wallet.
#    In mainnet mode the rail also needs its USDC address; until it is set,
#    settlement skips gracefully (non-blocking) instead of erroring.
#
#    Arbitrum is the recommended buildathon rail because it already has a
#    verified, live, Circle-issued USDC contract on chainId 42161. Arc mainnet is
#    not live yet, and 0G mainnet does not have a Circle/official USDC contract
#    published in the docs. For the Arbitrum Open House demo, set
#    SETTLEMENT_NETWORK=ARBITRUM and SETTLEMENT_ENV=mainnet, then fund the agent
#    wallet with Arbitrum USDC.
# ----------------------------------------------------------------------------
SETTLEMENT_NETWORK=ZERO_G
SETTLEMENT_ENV=testnet
# 0G mainnet settlement USDC (required before SETTLEMENT_ENV=mainnet on the ZERO_G rail)
#    BLOCKER: no verified contract address available from official 0G docs yet.
ZERO_G_MAINNET_USDC=
# Arc mainnet settlement (Arc mainnet beta est. 2026; USDC is a system predeploy)
ARC_MAINNET_RPC_URL=
ARC_MAINNET_USDC=
# Arbitrum settlement (preferred for the Arbitrum Open House — verified Circle USDC on mainnet)
ARBITRUM_ONE_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
ARBITRUM_MAINNET_USDC=          # defaults to 0xaf88d065e77c8cC2239327C5EDb3A432268e5831
ARBITRUM_TESTNET_USDC=          # defaults to 0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
# x402 gateway hardening
CLIENT_STATE_STORE=mongo       # persist rate-limit/credit/nonce state across restarts
SETTLEMENT_DAILY_CAP_USDC=50.0  # global daily safety cap on agent wallet spend
DATA_HUB_RECIPIENT_ADDRESS=     # Arbitrum treasury wallet that receives x402 payments
FREE_TIER_DAILY_CAP=100         # global free requests per IP/tenant per day
# ============================================================================

# Modal GLM Fallback (for AI inference when Venice/Gemini/0G fail)
# Get from https://modal.com - research token
MODAL_TOKEN=

# AI/ML API (400+ models, OpenAI-compatible fallback provider)
# Get from https://aimlapi.com — $0 free tier available
# Hackathon Partner: AI/ML API Challenge
AIML_API_KEY=

# Featherless API (OpenAI-compatible fallback provider in the AI failover chain)
# Get from https://featherless.ai
FEATHERLESS_API_KEY=

# NVIDIA API (OpenAI-compatible fallback provider — 100+ models, ~40 req/min free)
# Get from https://build.nvidia.com/ → generate API key
# Default model: deepseek/deepseek-v4-flash
NVIDIA_API_KEY=

# DashScope (Alibaba Cloud Bailian) — direct Qwen Cloud access
# OpenAI-compatible endpoint: https://dashscope.aliyuncs.com/compatible-mode/v1
# Get from https://bailian.console.aliyun.com/ → API-KEY management
# Inert when unset. Excluded from the default chat fallback chain; only
# reachable via `preferredProvider: 'dashscope'` (e.g. memory consolidation).
# Hackathon Partner: Qwen Cloud — Global AI Hackathon (Track 1: MemoryAgent)
# Default model: qwen-plus. Override with qwen-long for 1M-token context
# windows (ideal for memory consolidation), or qwen-max for highest quality.
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=

# Cognee (Agent Memory — cross-session learning)
# Get from https://www.cognee.ai/ or self-host
# Hackathon Partner: Cognee Challenge — "Best Use of Agent Memory"
COGNEE_API_URL=https://api.cognee.ai
COGNEE_API_KEY=
# Cognee tenant ID (optional — for multi-tenant isolation)
COGNEE_TENANT_ID=
# Memory TTL in days — memories older than this begin to decay (soft
# forgetting); at 2×TTL they're evicted by sweepStaleMemories (hard forgetting).
# Default 30. Implements "timely forgetting of outdated information".
COGNEE_MEMORY_TTL_DAYS=30

# Firecrawl (Macro Signal Monitoring — event-driven page watching)
# Get from https://firecrawl.dev — free tier available
# Monitors central bank pages, yield trackers, stablecoin depeg signals
FIRECRAWL_API_KEY=
FIRECRAWL_WEBHOOK_SECRET=

# Guardian Autonomous Loop (server-side cron, never sleeps)
# Secret for authenticating the cron → guardian-loop endpoint
GUARDIAN_LOOP_SECRET=
# Minimum confidence to auto-execute (0.0-1.0, default 0.6)
GUARDIAN_CONFIDENCE_THRESHOLD=0.6
# Default per-trade notional (USD) when a recommendation doesn't specify one
GUARDIAN_DEFAULT_TRADE_USD=10

# Advisor rate limiting (requests per minute per IP, default 20)
ADVISOR_RATE_LIMIT_PER_MIN=20

# Agent Identity (ERC-8004 + Self Protocol)
# Private key of the Self-registered agent identity (generated during QR registration flow)
AGENT_PRIVATE_KEY=
# URL where the ERC-8004 registration file is hosted
AGENT_URI=https://diversifiapp.vercel.app/.well-known/erc8004.json
