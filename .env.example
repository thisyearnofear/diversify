# Server-Side Keys (Keep Secret)
# Get from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=
OPENAI_API_KEY=

# SoSoValue API (Market Intelligence)
# Get from https://sosovalue-1.gitbook.io/sosovalue-api-doc
SOSOVALUE_API_KEY=

# Venice API (Primary AI Provider)
# Get from https://venice.ai/api
# Features: Web search, no data retention, OpenAI-compatible
VENICE_API_KEY=

# ElevenLabs API (TTS Fallback)
# Kept for redundancy - Venice TTS is primary
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# FREE API Keys (No Cost!)
# Get from Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Get from FRED (Federal Reserve Economic Data): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: CoinGecko Pro (has free tier): https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# LI.FI Integrator ID: https://portal.li.fi/
LIFI_INTEGRATOR_ID=
# LI.FI API Key (server-side only): required for LI.FI Earn data endpoints
LIFI_API_KEY=

# 1inch API Key (required for Arbitrum swaps): https://portal.1inch.dev/
ONEINCH_API_KEY=

# Bitso/Juno MXNB Integration (stage by default)
# Create a testing business account/API keys at https://stage.buildwithjuno.com
JUNO_ENV=stage
JUNO_API_KEY=
JUNO_API_SECRET=
# Use deterministic, clearly labeled sample Juno responses when sandbox keys are unavailable.
JUNO_DEMO_MODE=false
# Leave false unless intentionally testing sandbox deposits, quote execution, or redemptions.
JUNO_ENABLE_MUTATIONS=false

# Synth API Key (for market predictions and volatility data): https://docs.synthdata.co
SYNTH_API_KEY=

# Arc Network Agent Configuration
# Option 1: Circle Developer-Controlled Wallet (optional experimentation)
# Get from https://console.circle.com/ then run: pnpm create-wallet
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_ID=

# Smart Account Provider (select one)
# privy     — Privy Safe smart accounts (production, no key on server)
# safe4337  — Generic Safe + any signer (self-hosted, needs VAULT_PRIVATE_KEY + AA_BUNDLER_URL)
SMART_ACCOUNT_PROVIDER=privy

# Privy Smart Account (when SMART_ACCOUNT_PROVIDER=privy)
# Enable in Privy Dashboard: select Safe, configure Celo chain with bundler URL
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Generic Safe + ERC-4337 (when SMART_ACCOUNT_PROVIDER=safe4337)
# AA_BUNDLER_URL=https://api.pimlico.io/v2/42220/rpc?apikey=xxx
# AA_PAYMASTER_URL= (optional, for gas sponsorship)
VAULT_PRIVATE_KEY=
ARC_SETTLEMENT_START_BLOCK=

# Vault contract address (deploy: forge script contracts/vault/DeployVault.s.sol)
# When set, swaps go through contract's executeSwap() — on-chain enforcement
# When empty, falls back to direct signing (Phase 1)
VAULT_CONTRACT_ADDRESS=

# Agent spending limits in USDC
ARC_AGENT_DAILY_LIMIT=5.0
ARC_AGENT_TESTNET=true

# Email Services (choose one)
SENDGRID_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=agent@diversifi.app
EMAIL_PROVIDER=sendgrid

# Zapier MCP Integration (SECURE - treat like password)
ZAPIER_EMBED_ID=your_zapier_embed_id_here
ZAPIER_EMBED_SECRET=your_zapier_embed_secret_here

# Automation Webhooks (optional)
ZAPIER_WEBHOOK_URL=
MAKE_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Auth0 Token Vault (for user-delegated OAuth tokens)
# Get from Auth0 Dashboard: https://manage.auth0.com/
# Server-side (Management API access)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
# Client-side (connect buttons in UI)
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=

# Public Environment Variables (Safe for Browser)
# Get from Privy Dashboard: https://dashboard.privy.io/
# Used for social login (email/Google/X/Discord/Apple/SMS/Farcaster)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_ENABLE_PRIVY=true

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# API Base URL (leave empty for local dev; set to the Hetzner backend URL on production frontend)
# The frontend on Vercel routes API calls through here instead of using its own serverless functions
# NEXT_PUBLIC_API_BASE_URL=https://api.diversifi.famile.xyz
NEXT_PUBLIC_API_BASE_URL=

# Network RPCs (Optional Overrides)
NEXT_PUBLIC_CELO_RPC=https://forno.celo.org
NEXT_PUBLIC_ARC_RPC=https://rpc.testnet.arc.network
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/demo

# MongoDB Connection (for streak persistence)
# Get from MongoDB Atlas: https://www.mongodb.com/atlas
# Project: Diversifi (ID: 69c179dc1e75024408e787dd)
# Cluster: DiversifiCluster (Free tier M0, US_EAST_1)
# User: diversifi-user
# IP Whitelist: Only your server IP (no 0.0.0.0/0!)
MONGODB_URI=mongodb+srv://diversifi-user:YOUR_PASSWORD_HERE@diversificluster.cxx3kmd.mongodb.net/DiversifiCluster?retryWrites=true&w=majority

# Note: DeFiLlama, Yearn Finance, and World Bank APIs are FREE and need no keys!

# Hetzner backend — routes heavy AI API calls (analyze, chat, x402-gateway) to always-on server
# Eliminates Vercel cold starts and 15s timeout for Oracle/Guardian routes
# Leave unset to fall back to Vercel serverless (works fine, just slower)
HETZNER_API_URL=https://api.diversifi.famile.xyz

# 0G Serving (Decentralized AI Inference)
# OpenAI-compatible Router API: https://router-api.0g.ai/v1
# Get from 0G Discord or 0G Dashboard: https://docs.0g.ai/developer-hub/building-on-0g/compute-network/inference
# Models: deepseek-v4-pro (default), zai-org/GLM-5.1-FP8, qwen3.6-plus
# Serves as decentralized inference provider in AI failover chain
ZERO_G_SERVING_API_KEY=

# 0G Recommendation Ledger Contract (set after deployment)
# Records verifiable AI recommendations on 0G Chain
ZERO_G_LEDGER_CONTRACT=

# Modal GLM Fallback (for AI inference when Venice/Gemini/0G fail)
# Get from https://modal.com - research token
MODAL_TOKEN=

# AI/ML API (400+ models, OpenAI-compatible fallback provider)
# Get from https://aimlapi.com — $0 free tier available
# Hackathon Partner: AI/ML API Challenge
AIML_API_KEY=

# Cognee (Agent Memory — cross-session learning)
# Get from https://www.cognee.ai/ or self-host
# Hackathon Partner: Cognee Challenge — "Best Use of Agent Memory"
COGNEE_API_URL=https://api.cognee.ai
COGNEE_API_KEY=

# Firecrawl (Macro Signal Monitoring — event-driven page watching)
# Get from https://firecrawl.dev — free tier available
# Monitors central bank pages, yield trackers, stablecoin depeg signals
FIRECRAWL_API_KEY=
FIRECRAWL_WEBHOOK_SECRET=

# Guardian Autonomous Loop (server-side cron, never sleeps)
# Secret for authenticating the cron → guardian-loop endpoint
GUARDIAN_LOOP_SECRET=
# Minimum confidence to auto-execute (0.0-1.0, default 0.6)
GUARDIAN_CONFIDENCE_THRESHOLD=0.6
