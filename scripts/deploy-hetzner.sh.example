#!/usr/bin/env bash
# =============================================================================
# DiversiFi Hetzner Runtime Deployment Script (EXAMPLE)
#
# Copy this file to deploy-hetzner.sh and customize with your server details.
# DO NOT commit the customized version to git!
#
# Usage:
#   cp scripts/deploy-hetzner.sh.example scripts/deploy-hetzner.sh
#   # Edit deploy-hetzner.sh with your server details
#   chmod +x scripts/deploy-hetzner.sh
#   ./scripts/deploy-hetzner.sh
# =============================================================================
set -euo pipefail

# CUSTOMIZE THESE VALUES - USE ENVIRONMENT VARIABLES OR EDIT DIRECTLY
DEPLOY_DIR="${DEPLOY_DIR:-/opt/your-app-name}"
RUNTIME_DIR="${RUNTIME_DIR:-/opt/your-app-name-runtime}"
APP_NAME="${DEPLOY_APP_NAME:-your-app-name}"
PORT="${DEPLOY_PORT:-3042}"
REPO="${DEPLOY_REPO:-https://github.com/your-username/your-repo.git}"
BRANCH="${DEPLOY_BRANCH:-main}"

echo "🚀 DiversiFi Hetzner Deploy — $(date)"

# Frontend delivery is handled by Vercel. This script is for the Hetzner
# runtime/API deployment only.

# ── 1. Ensure pnpm is available ────────────────────────────────────────────
if ! command -v pnpm &>/dev/null; then
  echo "📦 Installing pnpm..."
  npm install -g pnpm
fi

# ── 2. Clone or pull latest code ────────────────────────────────────────────
if [ -d "$DEPLOY_DIR/.git" ]; then
  echo "🔄 Pulling latest from $BRANCH..."
  cd "$DEPLOY_DIR"
  git fetch origin
  git reset --hard "origin/$BRANCH"
else
  echo "📥 Cloning repo..."
  git clone --branch "$BRANCH" "$REPO" "$DEPLOY_DIR"
  cd "$DEPLOY_DIR"
fi

# ── 3. Verify .env exists ───────────────────────────────────────────────────
if [ ! -f "$DEPLOY_DIR/.env" ]; then
  echo "⚠️  No .env found at $DEPLOY_DIR/.env"
  echo "   Copy .env.example and fill in at minimum:"
  echo "     VENICE_API_KEY=..."
  echo "     GEMINI_API_KEY=..."
  echo "     SYNTH_API_KEY=..."
  echo "   Then re-run this script."
  exit 1
fi

# ── 4. Install dependencies ─────────────────────────────────────────────────
echo "📦 Installing dependencies..."
pnpm install --frozen-lockfile

# ── 5. Build ─────────────────────────────────────────────────────────────────
echo "🔨 Building..."
PORT=$PORT timeout 900s npm run build

echo "✅ Verifying Next runtime artifacts..."
test -f "$DEPLOY_DIR/.next/prerender-manifest.json"
test -f "$DEPLOY_DIR/.next/BUILD_ID"
test -f "$DEPLOY_DIR/.next/standalone/server.js"

echo "📦 Preparing lean runtime directory..."
rm -rf "$RUNTIME_DIR"
mkdir -p "$RUNTIME_DIR/.next" "$RUNTIME_DIR/public"
rsync -a --delete "$DEPLOY_DIR/.next/standalone/" "$RUNTIME_DIR/"
rsync -a --delete "$DEPLOY_DIR/.next/static/" "$RUNTIME_DIR/.next/static/"
rsync -a --delete "$DEPLOY_DIR/public/" "$RUNTIME_DIR/public/"
cp "$DEPLOY_DIR/.env" "$RUNTIME_DIR/.env"
cp "$DEPLOY_DIR/scripts/start-runtime.sh.example" "$RUNTIME_DIR/start-runtime.sh"
chmod +x "$RUNTIME_DIR/start-runtime.sh"

echo "🧹 Pruning build-only source artifacts..."
rm -rf "$DEPLOY_DIR/.next" "$DEPLOY_DIR/node_modules" "$DEPLOY_DIR/.turbo"

# ── 6. Start/reload server ──────────────────────────────────────────────────
echo "⚙️  Starting server..."
export APP_DIR="$RUNTIME_DIR"
export RUNTIME_BOOTSTRAP="$RUNTIME_DIR/start-runtime.sh"
pm2 delete "$APP_NAME" >/dev/null 2>&1 || true
pm2 start "$DEPLOY_DIR/scripts/pm2.ecosystem.config.cjs.example" --only "$APP_NAME"
sleep 8
pm2 status "$APP_NAME"

echo ""
echo "✅ Deploy complete!"
echo "   API running on http://127.0.0.1:$PORT"
echo "   Runtime directory: $RUNTIME_DIR"
echo "   Source checkout kept slim after deploy"
